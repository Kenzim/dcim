htmlcov/

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# Temporary / download artifacts
output.txt
output*.txt
*.zip
*.sfs

# ISO and Windows installer images
*.iso
isos/*.iso
*.wim
*.esd
*.vhd
*.vhdx

dhcpd.leases
dhcpd.pid
*.pid

# Uploaded assets (asset manager)
uploads/

# Runtime / generated config (machine-specific)
dhcp_config.json
tftp_config.json
dhcpd.conf

# Disk images (ignore contents except .gitkeep and README)
disk_images/**/*
!disk_images/**/.gitkeep
!disk_images/**/README.md

# Binary boot files (should never be in git)
*.squashfs
*.img
vmlinuz*
initrd*
initramfs*
*.cpio.gz
*.modloop

# Temporary OS files (keep config.json, ignore binaries)
tftp/pxe/temp_os/**/*.squashfs
tftp/pxe/temp_os/**/*.img
tftp/pxe/temp_os/**/vmlinuz*
tftp/pxe/temp_os/**/initrd*
tftp/pxe/temp_os/**/initramfs*
tftp/pxe/temp_os/**/*.cpio.gz
tftp/pxe/temp_os/**/*.modloop
tftp/pxe/temp_os/**/kernel/*
tftp/pxe/temp_os/**/initrd/*
tftp/pxe/temp_os/**/modloop/*
!tftp/pxe/temp_os/**/config.json

# Squashfs root (extracted filesystem)
tftp/squashfs-root/
squashfs-root/
usr/
sys/
newroot/

# System binaries and mount scripts
sbin/

# Run scripts (user-specific)
run_*.sh

# Local compose overrides and machine-specific compose files
docker-compose.override.yml
docker-compose.*.local.yml
*.local.yml
docker-compose.registry.yml

# Old PXE boot files
tftp/pxe/boot.ipxe
tftp/pxe/initrd/
tftp/pxe/kernel/
